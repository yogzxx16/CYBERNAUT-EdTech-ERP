# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/cybernaut_minutos

# JWT
JWT_ACCESS_SECRET=replace_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=replace_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_IN=15m

# Security
BCRYPT_SALT_ROUNDS=12
COOKIE_SECRET=replace_me_cookie_secret
COOKIE_SECURE=false

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
